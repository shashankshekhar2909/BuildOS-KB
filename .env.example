# Database (overridden in docker-compose for container networking)
DATABASE_URL=postgresql+asyncpg://buildos:buildos@localhost:5436/buildos

# Redis (overridden in docker-compose for container networking)
REDIS_URL=redis://localhost:6382

# LLM Providers — add keys for providers you use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# LiteLLM (optional local proxy — leave empty to call providers directly)
LITELLM_BASE_URL=

# Models
OKF_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small
SUMMARY_MODEL=groq/llama-3.1-8b-instant

# Discovery — comma-separated directories to scan
SCAN_DIRECTORIES=/home/shashank/project,/home/shashank/projects

# App
DEBUG=false
SECRET_KEY=change-me-in-production
REQUIRE_API_KEY=false
API_KEY=
